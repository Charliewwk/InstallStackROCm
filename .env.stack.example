# =========================
# Sistema
# =========================
TZ=America/Argentina/Buenos_Aires
COMPOSE_PROJECT_NAME=odoo_stack
LINUX_USER=__SET_ME__
LINUX_GROUP=__SET_ME__

HOME_DIR=/home/__SET_ME__
SOURCE_ENV=/home/__SET_ME__/.env.stack
TARGET_ENV=/srv/.env

# =========================
# Paths
# =========================
BASE_DIR=/srv
ODOO_DIR=/srv/odoo
NGINX_DIR=/srv/nginx
POSTGRES_DIR=/srv/postgres
ONLYOFFICE_DIR=/srv/onlyoffice
OPENCLAW_DIR=/srv/openclaw
VLLM_DIR=/srv/vllm
LLAMACPP_DIR=/srv/llamacpp
HF_CACHE_DIR=/srv/huggingface
BACKUPS_DIR=/srv/backups

COMPOSE_CPU_FILE=/srv/docker-compose.cpu.yml
COMPOSE_GPU_FILE=/srv/docker-compose.gpu.yml

# =========================
# ROCm / requisitos oficiales Ubuntu 24.04
# =========================
ROCM_INSTALLER_SERIES=7.2.2
ROCM_INSTALLER_BUILD=7.2.2.70202-1
ROCM_UBUNTU_CODENAME=noble
ROCM_TARGET_USER=christian

ROCM_REQUIRED_UBUNTU_SERIES=24.04
ROCM_REQUIRED_UBUNTU_POINT=24.04.4
ROCM_REQUIRED_KERNEL_GA_PREFIX=6.8.
ROCM_REQUIRED_KERNEL_HWE_PREFIX=6.17.
ROCM_REQUIRED_GLIBC=2.39

# =========================
# PostgreSQL
# =========================
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=__SET_ME__

# =========================
# Odoo
# Ajustado para hasta 4 usuarios livianos
# =========================
ODOO_ADMIN_PASSWORD=__SET_ME__
ODOO_DB_HOST=db
ODOO_DB_PORT=5432
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=__SET_ME__
ODOO_WORKERS=2
ODOO_MAX_CRON_THREADS=1
ODOO_LIMIT_MEMORY_HARD=2147483648
ODOO_LIMIT_MEMORY_SOFT=1610612736
ODOO_LIMIT_REQUEST=8192
ODOO_LIMIT_TIME_CPU=600
ODOO_LIMIT_TIME_REAL=1200
ODOO_DBFILTER=.*

# =========================
# Dominios / Nginx / SSL
# =========================
ODOO_HOST=odoo.lan
DOCS_HOST=docs.odoo.lan
CLAW_HOST=claw.odoo.lan

SSL_COUNTRY=AR
SSL_STATE=Buenos_Aires
SSL_CITY=Ciudad_Autónoma_de_Buenos_Aires
SSL_ORG=Proyecto
SSL_UNIT=Infraestructura
SSL_COMMON_NAME=odoo.lan

# =========================
# OnlyOffice
# =========================
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=__SET_ME__
ONLYOFFICE_JWT_HEADER=Authorization
ONLYOFFICE_USE_UNAUTHORIZED_STORAGE=true

# =========================
# OpenClaw / Telegram
# =========================
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=__SET_ME__
OPENCLAW_BIND=lan
OPENCLAW_PORT=18789

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=__SET_ME__
TELEGRAM_DM_POLICY=pairing
TELEGRAM_GROUP_POLICY=allowlist

OPENCLAW_DEFAULT_MODEL=vllm/qwen2.5-7b-instruct-awq
OPENCLAW_FALLBACK_MODEL=llamacpp/qwen2.5-7b-instruct-gguf

# =========================
# vLLM principal (ROCm)
# =========================
VLLM_IMAGE=vllm/vllm-openai-rocm:latest
VLLM_PORT=8000
VLLM_API_KEY=__SET_ME__
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
VLLM_MODEL_ALIAS=qwen2.5-7b-instruct-awq
VLLM_MAX_MODEL_LEN=32768
VLLM_MAX_TOKENS=1024
VLLM_MAX_NUM_SEQS=1
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_TOOL_CALL_PARSER=hermes

# =========================
# llama.cpp fallback (Vulkan)
# LLAMACPP_AUTOSTART=false para no cargar ambos modelos al mismo tiempo
# =========================
LLAMACPP_AUTOSTART=false
LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-vulkan
LLAMACPP_PORT=8080
LLAMACPP_API_KEY=__SET_ME__
LLAMACPP_MODEL_ALIAS=qwen2.5-7b-instruct-gguf
LLAMACPP_HF_REPO=Qwen/Qwen2.5-7B-Instruct-GGUF:Q4_K_M
LLAMACPP_CTX_SIZE=8192
LLAMACPP_MAX_TOKENS=2048
LLAMACPP_N_GPU_LAYERS=999
LLAMACPP_THREADS=8
LLAMACPP_PARALLEL=1

# =========================
# Hugging Face
# =========================
HF_TOKEN=__SET_ME__

# =========================
# Validación placa de video
# =========================
GPU_EXPECTED_ROCM_REGEX='AMD Radeon|gfx'
GPU_EXPECTED_CLINFO_REGEX='AMD Radeon|gfx'
GPU_EXPECTED_VULKAN_REGEX='AMD Radeon|RADV|gfx'